{
  "name": "videochatservice",
  "version": "1.0.0",
  "description": "Microservicio de videollamadas y chat en tiempo real para plataforma de psicología",
  "main": "server.js",
  "scripts": {
 "start": "npm ci --omit=dev --no-audit --no-fund && node server.js",
    "dev": "nodemon server.js",
    "test:events": "node tests/events-api-test.js",
    "test:chat": "node tests/chat-realtime-test.js",
    "test:webrtc": "node tests/webrtc-signaling-test.js",
    "test:realtime": "npm run test:chat && npm run test:webrtc",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src/"
  },
  "keywords": [
    "videochat",
    "webrtc",
    "socket.io",
    "microservicio",
    "psicologia"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.23.0",
    "socket.io": "^4.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.40.0",
    "eslint-config-prettier": "^8.8.0",
    "jest": "^29.5.0",
    "nodemon": "^2.0.20",
    "prettier": "^2.8.8",
    "socket.io-client": "^4.8.3"
  }
}
